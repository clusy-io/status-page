# All configuration that matters lives in status.config.ts — env vars are
# only for secrets and per-deployment overrides.

# ── Cron protection (recommended) ────────────────────────────────────────────
# Set in the Vercel project env. Vercel sends it as a Bearer token to
# /api/cron; without it the endpoint is open (harmless, but spammable).
# CRON_SECRET=

# ── Uptime history + auto incidents (optional) ───────────────────────────────
# Link a Vercel KV / Upstash Redis store to enable the 90-day uptime bars and
# auto-detected incidents. Vercel injects these automatically when you link a
# store to the project; set them manually for other Upstash-compatible KVs.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── Notifications (optional) ─────────────────────────────────────────────────
# Email subscriptions (double opt-in) — needs KV above plus a Resend API key.
# The From address/domain is set in status.config.ts (NOTIFICATIONS.emailFrom)
# and must be verified in your Resend account. Without a key, the subscribe
# button is hidden and no email is ever sent.
# RESEND_API_KEY=re_xxx

# Webhook announcements — set any of these to also (or instead) push incident
# updates to a channel. No KV-stored subscribers involved; just a URL.
# NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# NOTIFY_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
# NOTIFY_WEBHOOK_URL=https://example.com/hooks/status   # generic JSON POST

# ── Overrides (optional) ─────────────────────────────────────────────────────
# Overrides the `timezone` set in status.config.ts for this deployment.
# STATUS_TIMEZONE=America/Los_Angeles

# Referenced from status.config.ts if you use the supabaseAuthProbe helper
# with an anon key. Publishable key only — never a service-role key.
# STATUS_SUPABASE_ANON_KEY=sb_publishable_xxx
